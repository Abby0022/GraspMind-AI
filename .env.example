# ══════════════════════════════════════════════════════════════
# GraspMind AI — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit the .env file to version control!
# ══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000

# ── LLM ──────────────────────────────────────────────────────
GROQ_API_KEY=gsk_...                      # Free: groq.com
OLLAMA_BASE_URL=http://localhost:11434
LLM_PROVIDER=groq                         # groq | ollama | openrouter
LLM_MODEL=llama-3.3-70b-versatile

# ── Embeddings (Google Gemini) ───────────────────────────────
GOOGLE_API_KEY=                            # Free: aistudio.google.com
EMBEDDING_PROVIDER=google
EMBEDDING_MODEL=gemini-embedding-2
EMBEDDING_DIMENSIONS=3072                  # Matryoshka: 3072/768/256

# ── Qdrant ───────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333           # Local Docker or cloud.qdrant.io
QDRANT_API_KEY=

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...                   # Publishable key
SUPABASE_SERVICE_KEY=eyJ...                # BACKEND ONLY — never in frontend!

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379           # Local Docker or Upstash

# ── Security ─────────────────────────────────────────────────
JWT_SECRET=                                # Min 256-bit, generate with: openssl rand -hex 32
RATE_LIMIT_CHAT=60                         # requests/minute
RATE_LIMIT_UPLOAD=10                       # requests/minute

# ── Frontend (NEXT_PUBLIC_ vars only) ────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
